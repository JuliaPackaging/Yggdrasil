Guard <linux/openat2.h> inclusion: rsync 3.4.3 includes it unconditionally
inside #ifdef __linux__, but the header (and the openat2 syscall) only exist
on Linux 5.6+. When the kernel headers are older, fall back to the existing
portable per-component-walk path in secure_relative_open().

--- a/syscall.c
+++ b/syscall.c
@@ -33,9 +33,10 @@
 #include <sys/sysmacros.h>
 #endif

-#ifdef __linux__
+#if defined(__linux__) && defined(HAVE_LINUX_OPENAT2_H)
 #include <sys/syscall.h>
 #include <linux/openat2.h>
+#define RSYNC_HAVE_OPENAT2 1
 #endif

 extern int dry_run;
@@ -1693,7 +1694,7 @@ static int path_has_dotdot_component(const char *p)
 	return 0;
 }

-#ifdef __linux__
+#ifdef RSYNC_HAVE_OPENAT2
 static int secure_relative_open_linux(const char *basedir, const char *relpath, int flags, mode_t mode)
 {
 	struct open_how how;
@@ -1794,7 +1795,7 @@ int secure_relative_open(const char *basedir, const char *relpath, int flags, mo
 		return -1;
 	}

-#ifdef __linux__
+#ifdef RSYNC_HAVE_OPENAT2
 	{
 		int fd = secure_relative_open_linux(basedir, relpath, flags, mode);
