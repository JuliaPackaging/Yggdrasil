From 30810c7b3c9e393892ba2b75722ac7933ed3cd8e Mon Sep 17 00:00:00 2001
From: Sandbox User <sandbox@localhost>
Date: Fri, 17 Jul 2026 12:54:57 +0000
Subject: [PATCH] [aievec] Legalize integer vector arithmetic for AIE2p

A vectorized i16 -> i32 matmul reaches Peano as a <16 x s32> G_MUL and stops it
with "unable to legalize instruction". There is no i32 vector multiply: the MAC
multiplies i16 into an i32 accumulator, which is what aievec.mac_elem is for.

`arith` is legal by default in configureAIEVecCommonLegalizations, so an op is
only rewritten if a legality rule names it. Two gaps let the multiply through:

  - configureAIEVecV2PLegalizations had no integer rules at all, while
    configureAIEVecV2Legalizations has arith::MulIOp. On AIE2p nothing ever made
    a vector multiply illegal.

  - Neither target names arith::AddIOp. MulIOp's rule keeps a multiply legal when
    it feeds an add, deferring to ConvertMulAddToAIEVecFMAElemOpPattern, but that
    pattern matches on the add -- so with the add legal it never runs, and the
    multiply is spared for a rewrite that never happens. The MAC was therefore
    unreachable on AIE2 as well as AIE2p.

Share both rules between the two targets. Only the MAC-shaped add is marked
illegal: a plain integer vector add has no pattern registered for AIE2/AIE2p --
LowerVectorAddIOpToAIEVecAddElemOp is defined but never added to either set --
so marking those illegal would trade a missing instruction for a failed
conversion.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 .../Transforms/VectorToAIEVecConversions.cpp  | 76 +++++++++++++++----
 1 file changed, 61 insertions(+), 15 deletions(-)

diff --git a/lib/Dialect/AIEVec/Transforms/VectorToAIEVecConversions.cpp b/lib/Dialect/AIEVec/Transforms/VectorToAIEVecConversions.cpp
index ae4986ce4b..567b616d98 100644
--- a/lib/Dialect/AIEVec/Transforms/VectorToAIEVecConversions.cpp
+++ b/lib/Dialect/AIEVec/Transforms/VectorToAIEVecConversions.cpp
@@ -5311,6 +5311,60 @@ static void configureAIEVecCommonLegalizations(ConversionTarget &target) {
   target.addLegalOp<vector::ExtractOp, vector::InsertOp>();
 }
 
+// Integer legalizations shared by AIE2 and AIE2p, which have the same integer MAC.
+//
+// `arith` is legal by default (see configureAIEVecCommonLegalizations), so an
+// integer vector op that is not named here is never rewritten. It then reaches
+// Peano, which reports e.g. "unable to legalize instruction: <16 x s32> G_MUL" --
+// there is no i32 vector multiply, the MAC multiplies i16 into an i32
+// accumulator -- long after any pass that could have said so.
+static void configureAIEVecIntegerLegalizations(ConversionTarget &target) {
+  target.addDynamicallyLegalOp<arith::MulIOp>([](arith::MulIOp op) {
+    auto resultType = dyn_cast<VectorType>(op.getType());
+    if (!resultType)
+      return true;
+    auto isAddOp = [&](Operation *op) { return isa<arith::AddIOp>(op); };
+    // Verify it is not a part of MAC
+    if (op->hasOneUse() && llvm::any_of(op->getUsers(), isAddOp))
+      return true;
+
+    auto resultElWidth = resultType.getElementType().getIntOrFloatBitWidth();
+    unsigned laneSize = getVectorLaneSize(resultType);
+
+    return (laneSize != 32 || (resultElWidth != 16 && resultElWidth != 8)) &&
+           ((laneSize != 16 && laneSize != 32) || resultElWidth != 32);
+  });
+
+  // A multiply feeding an add is the MAC that
+  // ConvertMulAddToAIEVecFMAElemOpPattern rewrites, and the rule above keeps the
+  // multiply legal on that basis. But the pattern matches on the *add*, so unless
+  // the add is illegal it never runs: the multiply is then spared for a rewrite
+  // that never happens, and both reach Peano.
+  //
+  // Only the MAC shape is marked illegal. A plain integer vector add has no
+  // pattern here -- LowerVectorAddIOpToAIEVecAddElemOp is defined but never added
+  // to the AIE2/AIE2p sets -- so marking those illegal would trade a missing
+  // instruction for a failed conversion.
+  target.addDynamicallyLegalOp<arith::AddIOp>([](arith::AddIOp op) {
+    auto resultType = dyn_cast<VectorType>(op.getType());
+    if (!resultType)
+      return true;
+
+    // The shapes ConvertMulAddToAIEVecFMAElemOpPattern accepts.
+    unsigned resultElWidth =
+        resultType.getElementType().getIntOrFloatBitWidth();
+    unsigned laneSize = getVectorLaneSize(resultType);
+    if ((laneSize != 32 || resultElWidth != 16) &&
+        (laneSize != 16 || resultElWidth != 32))
+      return true;
+
+    auto fromMul = [](Value v) {
+      return v.getDefiningOp<arith::MulIOp>() != nullptr;
+    };
+    return !fromMul(op.getLhs()) && !fromMul(op.getRhs());
+  });
+}
+
 static void configureAIEVecV1Legalizations(ConversionTarget &target) {
   target.addDynamicallyLegalOp<arith::MulIOp>(
       [](arith::MulIOp op) { return !isa<VectorType>(op.getType()); });
@@ -5582,6 +5636,10 @@ static void configureAIEVecV2PLegalizations(ConversionTarget &target) {
   // (LLVMIR backend), so LowerVectorSIToFPI16BF16AIE2pPattern is tried
   // ahead of the per-lane scalarize fallback by pattern benefit.
   target.addLegalOp<vector::ShuffleOp>();
+
+  // AIE2p had none of these, so integer vector arithmetic passed through to Peano
+  // unrewritten.
+  configureAIEVecIntegerLegalizations(target);
 }
 
 static void configureAIEVecV2Legalizations(ConversionTarget &target) {
@@ -5645,21 +5703,9 @@ static void configureAIEVecV2Legalizations(ConversionTarget &target) {
     return true; // legal - not supported
   });
 
-  target.addDynamicallyLegalOp<arith::MulIOp>([](arith::MulIOp op) {
-    auto resultType = dyn_cast<VectorType>(op.getType());
-    if (!resultType)
-      return true;
-    auto isAddOp = [&](Operation *op) { return isa<arith::AddIOp>(op); };
-    // Verify it is not a part of MAC
-    if (op->hasOneUse() && llvm::any_of(op->getUsers(), isAddOp))
-      return true;
-
-    auto resultElWidth = resultType.getElementType().getIntOrFloatBitWidth();
-    unsigned laneSize = getVectorLaneSize(resultType);
-
-    return (laneSize != 32 || (resultElWidth != 16 && resultElWidth != 8)) &&
-           ((laneSize != 16 && laneSize != 32) || resultElWidth != 32);
-  });
+  // Was a MulIOp rule alone, which left the multiply legal whenever it fed an add,
+  // deferring to a MAC pattern that could not run because the add was legal too.
+  configureAIEVecIntegerLegalizations(target);
 
   target.addDynamicallyLegalOp<arith::MulFOp>([](arith::MulFOp op) {
     auto resultType = dyn_cast<VectorType>(op.getType());
-- 
