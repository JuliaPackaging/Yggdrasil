--- a/src/runtime_src/core/common/detail/linux/xilinx_xrt.h
+++ b/src/runtime_src/core/common/detail/linux/xilinx_xrt.h
@@ -31,10 +31,18 @@
 sfs::path
 xilinx_xrt()
 {
-  // This returns CMAKE_INSTALL_PREFIX.  The internal default cmake
-  // install path is /opt/xilinx/xrt, for upstreaming most likely /usr.
-  // In relocatable installs XILINX_XRT should be set and this function
-  // will not be called.
+  // Prefer this shared library's own location so a relocatable install -- a
+  // Julia JLL artifact placed anywhere on disk, say -- works without XILINX_XRT
+  // being set. libxrt_coreutil.so lives in <root>/lib, so the XRT root is two
+  // levels up from the DSO. Fall back to the compile-time CMAKE_INSTALL_PREFIX
+  // (below) when the DSO location cannot be determined.
+  Dl_info info{};
+  if (dladdr(reinterpret_cast<const void*>(&xilinx_xrt), &info) && info.dli_fname) {
+    sfs::path lib{info.dli_fname};
+    auto root = lib.parent_path().parent_path();
+    if (!root.empty())
+      return root;
+  }
   return sfs::path(XRT_INSTALL_PREFIX);
 }
