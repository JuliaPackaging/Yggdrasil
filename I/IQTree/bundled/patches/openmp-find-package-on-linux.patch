Use find_package(OpenMP) on Linux instead of the bundled libomp.a.

The bundled lib/libomp.a and liblinux_arm/libomp.a are built against
glibc (reference `__sysconf`) and fail to link on musl. libgomp from the
Yggdrasil CompilerSupportLibraries_jll covers both libcs. macOS, FreeBSD,
and Windows branches are unchanged.

--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -575,17 +575,9 @@
             endif()
       endif()
     elseif (UNIX AND NOT ${CMAKE_SYSTEM_NAME} STREQUAL "FreeBSD")
-      if (__ARM_NEON)
-        link_directories(${PROJECT_SOURCE_DIR}/liblinux_arm)
-        LIST(APPEND STATIC_LIBS "${PROJECT_SOURCE_DIR}/liblinux_arm/libomp.a" "${PROJECT_SOURCE_DIR}/liblinux_arm/libz.a")
-        set(BUNDLED_OMP_LIB "${PROJECT_SOURCE_DIR}/liblinux_arm/libomp.a")
-      elseif(BUILD_LIB)
-        find_package(OpenMP)
-      else()
-        link_directories(${PROJECT_SOURCE_DIR}/lib)
-        LIST(APPEND STATIC_LIBS "${PROJECT_SOURCE_DIR}/lib/libomp.a" "${PROJECT_SOURCE_DIR}/lib/libz.a")
-        set(BUNDLED_OMP_LIB "${PROJECT_SOURCE_DIR}/lib/libomp.a")
-      endif()
+      # Bundled libomp.a links against glibc; use system OpenMP instead so
+      # the build works on musl too. libgomp comes from the toolchain.
+      find_package(OpenMP REQUIRED)
     elseif (WIN32)
         link_directories(${PROJECT_SOURCE_DIR}/lib)
     endif()
